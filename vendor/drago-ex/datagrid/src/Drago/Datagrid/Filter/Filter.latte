{templateType Drago\Datagrid\Filter\FilterTextTemplate}
{varType Nette\Application\UI\Form $form}

<form n:name="form" class="ajax datagrid-filters" data-bs-theme="light" data-naja-history="replace">
    <div class="datagrid-toolbar mt-2">
        <div class="d-inline-flex flex-wrap align-items-end gap-3">
            {foreach $form->getControls() as $input}
                {varType Nette\Forms\Controls\BaseControl $input}
                <div class="form-floating form-floating-sm">
                    {$input->getControl()->class('form-control datagrid-control')->placeholder(($input->control->placeholder|translate) ?? ' ')}
                    <label>{$input->getLabel() ?? null}</label>
                </div>
            {/foreach}

            {if $hasActiveFilters}
                <a n:href="resetFilters!" class="btn btn-secondary ajax datagrid-reset-btn" data-naja-history="replace">
                    {_'Reset'}
                </a>
            {/if}
        </div>
    </div>
</form>
