{templateType Drago\Datagrid\PageSize\PageSizeTemplate}
<div class="d-flex align-items-center mb-0">
    <label class="me-2 mb-0 small text-muted">{_'Items per page'}</label>
    <select class="form-select form-select-sm w-auto"
            data-items-page
            data-url-template="{link setPageSize!, size => '__SIZE__'}">
        <option n:foreach="$items as $value => $label"
                value="{$value}"
                n:attr="selected => $value === $currentSize">
            {_$label}
        </option>
    </select>
</div>
