{templateType Drago\Datagrid\DataGridTemplate}
{do $from = $totalItems > 0 ? ($page - 1) * $itemsPerPage + 1 : 0}
{do $to = $totalItems > 0 ? min($from + $itemsPerPage - 1, $totalItems) : 0}

<div class="d-flex flex-column flex-md-row align-items-baseline gap-2">
    <div class="text-muted small text-nowrap order-2 order-md-1">
        {if $totalItems > 0}
            {_Showing} {$from}–{$to} {_of} {$totalItems} {_items}
        {else}
            {_'No items'}
        {/if}
    </div>

    <div n:class="'order-1 order-md-2 mx-md-auto', $itemsPerPage >= $totalItems ? 'invisible'">
        {control paginator}
    </div>

    <div class="order-3 d-flex align-items-center text-nowrap">
        {control pageSize}
    </div>
</div>
