#!/usr/bin/env php
<?php
declare(strict_types=1);

use Composer\InstalledVersions;

require __DIR__ . '/../vendor/autoload.php';

$projectDir = dirname(__DIR__);
$targetDir = $projectDir . '/migrations';

if (!is_dir($targetDir)) {
	mkdir($targetDir, 0777, true);
}

$targetRealPath = realpath($targetDir);
$targetLabel = str_replace('\\', '/', substr($targetDir, strlen($projectDir)));
$rootPackageName = InstalledVersions::getRootPackage()['name'] ?? null;

$green = "\033[32m";
$yellow = "\033[33m";
$red = "\033[31m";
$reset = "\033[0m";

echo "Scanning vendor packages for migration SQL files...\n\n";

$found = 0;
$copied = 0;
$skipped = 0;

foreach (InstalledVersions::getInstalledPackages() as $packageName) {
	if ($packageName === $rootPackageName) {
		continue;
	}

	$packagePath = InstalledVersions::getInstallPath($packageName);

	if (!$packagePath || !is_dir($packagePath)) {
		continue;
	}

	$migrationDirs = [
			$packagePath . '/migration',
			$packagePath . '/migrations',
	];

	foreach ($migrationDirs as $dir) {
		if (!is_dir($dir)) {
			continue;
		}

		if ($targetRealPath !== false && realpath($dir) === $targetRealPath) {
			continue;
		}

		foreach (glob($dir . '/*.sql') as $file) {
			if (!is_file($file)) {
				continue;
			}

			$found++;
			$filename = basename($file);
			$targetFile = $targetDir . '/' . $filename;

			if (file_exists($targetFile)) {
				echo "{$yellow}-> Skipped (exists){$reset} {$filename}\n";
				$skipped++;
				continue;
			}

			if (copy($file, $targetFile)) {
				echo "{$green}+ Copied{$reset} {$packageName} -> {$filename}\n";
				$copied++;
			} else {
				echo "{$red}! Failed{$reset} {$file}\n";
			}
		}
	}
}

if ($found === 0) {
	echo "{$yellow}No migration SQL files found.{$reset}\n";
} elseif ($copied === 0) {
	echo "\n{$yellow}Done. No new files copied into {$targetLabel}. Skipped {$skipped} existing files.{$reset}\n";
} else {
	echo "\n{$green}Done. Copied {$copied} files into {$targetLabel}. Skipped {$skipped} existing files.{$reset}\n";
}
